{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "_comment": "Mutation testing focused on the math-heavy color conversion / gamut code where mutations map directly to real bugs.",
  "packageManager": "yarn",
  "testRunner": "vitest",
  "vitest": {
    "configFile": "vitest.config.ts"
  },
  "reporters": ["html", "clear-text", "progress"],
  "coverageAnalysis": "perTest",
  "mutate": [
    "src/colorModels/**/*.ts",
    "src/gamut.ts",
    "src/transfer.ts",
    "src/channels.ts"
  ],
  "ignorePatterns": [
    "dist",
    "coverage",
    "reports",
    "playground",
    "bench",
    ".stryker-tmp"
  ],
  "incremental": true,
  "thresholds": {
    "high": 90,
    "low": 80,
    "break": 70
  }
}
