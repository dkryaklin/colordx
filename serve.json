{
  "rewrites": [
    { "source": "/styles.css", "destination": "/playground/styles.css" },
    { "source": "/app.js", "destination": "/playground/app.js" },
    { "source": "/manifest.webmanifest", "destination": "/playground/manifest.webmanifest" },
    { "source": "/index.mjs", "destination": "/dist/index.mjs" },
    { "source": "/chunk-:name.mjs", "destination": "/dist/chunk-:name.mjs" },
    { "source": "/plugins/a11y.mjs", "destination": "/dist/plugins/a11y.mjs" },
    { "source": "/plugins/harmonies.mjs", "destination": "/dist/plugins/harmonies.mjs" },
    { "source": "/plugins/hsv.mjs", "destination": "/dist/plugins/hsv.mjs" },
    { "source": "/plugins/hwb.mjs", "destination": "/dist/plugins/hwb.mjs" },
    { "source": "/plugins/lab.mjs", "destination": "/dist/plugins/lab.mjs" },
    { "source": "/plugins/lch.mjs", "destination": "/dist/plugins/lch.mjs" },
    { "source": "/plugins/mix.mjs", "destination": "/dist/plugins/mix.mjs" },
    { "source": "/plugins/p3.mjs", "destination": "/dist/plugins/p3.mjs" },
    { "source": "/", "destination": "/playground/index.html" }
  ]
}
